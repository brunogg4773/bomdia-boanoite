<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Mensagem Romântica</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Nunito:wght@300;400&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    html, body {
      min-height: 100%;
      font-family: 'Nunito', sans-serif;
    }

    #app {
      min-height: 100vh;
      position: relative;
      overflow: hidden;
      transition: background 1.2s ease;
    }

    #app.morning {
      background: linear-gradient(160deg, #fff1e8 0%, #fde8d8 30%, #f9d5e5 60%, #ecdff5 100%);
    }

    #app.night {
      background: linear-gradient(160deg, #0d0520 0%, #1a0a2e 35%, #2d1654 70%, #1a0a2e 100%);
    }

    /* ── Stars ── */
    .stars { position: fixed; inset: 0; pointer-events: none; opacity: 0; transition: opacity 1.2s ease; z-index: 0; }
    #app.night .stars { opacity: 1; }
    .star {
      position: absolute; border-radius: 50%; background: white;
      animation: twinkle 3s infinite ease-in-out;
    }
    @keyframes twinkle {
      0%, 100% { opacity: 0.3; transform: scale(1); }
      50%       { opacity: 1;   transform: scale(1.3); }
    }

    /* ── Celestial bodies ── */
    .celestial {
      position: fixed; top: 24px; right: 24px;
      width: 60px; height: 60px; z-index: 1;
      pointer-events: none;
    }
    @media (min-width: 480px) { .celestial { width: 70px; height: 70px; top: 40px; right: 60px; } }

    .sun-wrap, .moon-wrap { position: absolute; top: 0; left: 0; transition: all 1.2s ease; }
    #app.morning .sun-wrap  { opacity: 1; transform: translateY(0); }
    #app.morning .moon-wrap { opacity: 0; transform: translateY(-20px); }
    #app.night   .sun-wrap  { opacity: 0; transform: translateY(-20px); }
    #app.night   .moon-wrap { opacity: 1; transform: translateY(0); }

    .sun-body {
      width: 60px; height: 60px; border-radius: 50%;
      background: radial-gradient(circle at 40% 40%, #fff6a0, #ffd34e, #ffaa00);
      box-shadow: 0 0 28px 8px rgba(255,200,50,.35);
      animation: rotateSun 20s linear infinite;
    }
    @media (min-width: 480px) { .sun-body { width: 70px; height: 70px; } }
    @keyframes rotateSun { to { transform: rotate(360deg); } }

    .moon-body {
      width: 60px; height: 60px; border-radius: 50%;
      background: radial-gradient(circle at 35% 35%, #fffff0, #e8e0c8, #c8c0a8);
      box-shadow: 0 0 18px 4px rgba(200,200,150,.28), inset -8px -4px 0 rgba(0,0,0,.12);
      animation: floatMoon 4s ease-in-out infinite;
    }
    @media (min-width: 480px) { .moon-body { width: 70px; height: 70px; } }
    @keyframes floatMoon { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-6px); } }

    /* ── Petals ── */
    .petal {
      position: fixed; pointer-events: none;
      border-radius: 60% 40% 60% 40%; opacity: 0;
      animation: petalFall 9s ease-in-out infinite;
      z-index: 0;
    }
    @keyframes petalFall {
      0%   { transform: translateY(-20px) rotate(0deg)   translateX(0);   opacity: 0; }
      10%  { opacity: .7; }
      90%  { opacity: .35; }
      100% { transform: translateY(110vh) rotate(360deg) translateX(30px); opacity: 0; }
    }

    /* ── Fireflies ── */
    .firefly {
      position: fixed; width: 3px; height: 3px; border-radius: 50%;
      background: rgba(255,255,150,.9); pointer-events: none;
      box-shadow: 0 0 6px 2px rgba(255,255,100,.6);
      animation: fireflyDance 7s ease-in-out infinite;
      z-index: 0;
    }
    @keyframes fireflyDance {
      0%   { transform: translate(0,0);                              opacity: 0; }
      20%  { opacity: 1; }
      50%  { transform: translate(var(--fx), var(--fy));             opacity: .8; }
      80%  { opacity: .5; }
      100% { transform: translate(calc(var(--fx)*.4), calc(var(--fy)*2)); opacity: 0; }
    }

    /* ── Layout ── */
    .content {
      position: relative; z-index: 10;
      display: flex; flex-direction: column; align-items: center;
      padding: 24px 16px 40px;
      min-height: 100vh;
    }
    @media (min-width: 480px) { .content { padding: 36px 20px 48px; } }

    /* ── Toggle ── */
    .toggle-wrap {
      display: flex; gap: 6px;
      background: rgba(255,255,255,.25);
      backdrop-filter: blur(12px);
      border-radius: 50px; padding: 5px;
      border: 1px solid rgba(255,255,255,.4);
      margin-bottom: 22px;
    }
    .toggle-btn {
      padding: 9px 20px; border-radius: 40px; border: none; cursor: pointer;
      font-family: 'Nunito', sans-serif; font-size: 14px; font-weight: 400;
      transition: all .4s ease; background: transparent;
      -webkit-tap-highlight-color: transparent;
    }
    @media (min-width: 380px) { .toggle-btn { padding: 9px 26px; } }
    #app.morning .toggle-btn { color: #6a3a4a; }
    #app.night   .toggle-btn { color: rgba(255,255,255,.7); }
    .toggle-btn.active { color: white !important; box-shadow: 0 2px 12px rgba(0,0,0,.15); }
    #app.morning .toggle-btn.active { background: linear-gradient(135deg,#c4405a,#e86c8a); }
    #app.night   .toggle-btn.active { background: linear-gradient(135deg,#4a2080,#7040c0); }

    /* ── Language chips ── */
    .lang-section { margin-bottom: 20px; text-align: center; width: 100%; }
    .lang-label {
      font-size: 11px; letter-spacing: 2px; text-transform: uppercase;
      margin-bottom: 10px; display: block;
    }
    #app.morning .lang-label { color: #9a6a7a; }
    #app.night   .lang-label { color: rgba(200,180,255,.7); }

    .lang-grid {
      display: flex; flex-wrap: wrap; gap: 6px;
      justify-content: center; max-width: 440px; margin: 0 auto;
    }
    .lang-chip {
      padding: 6px 13px; border-radius: 30px; font-size: 13px; cursor: pointer;
      border: 1px solid; transition: all .3s ease;
      font-family: 'Nunito', sans-serif; font-weight: 400;
      -webkit-tap-highlight-color: transparent;
      user-select: none;
    }
    #app.morning .lang-chip          { border-color: rgba(196,64,90,.3);    color: #7a3a4a;               background: rgba(255,255,255,.5); }
    #app.morning .lang-chip.active,
    #app.morning .lang-chip:hover    { background: rgba(196,64,90,.15);      border-color: #c4405a;         color: #c4405a; }
    #app.night   .lang-chip          { border-color: rgba(160,120,240,.3);   color: rgba(200,180,255,.8);   background: rgba(255,255,255,.05); }
    #app.night   .lang-chip.active,
    #app.night   .lang-chip:hover    { background: rgba(120,80,200,.25);     border-color: rgba(160,120,240,.8); color: #c8b4ff; }

    /* ── Card ── */
    .card {
      border-radius: 24px; padding: 36px 24px 32px;
      width: 100%; max-width: 480px; text-align: center;
      position: relative; overflow: hidden;
      transition: background .8s ease, box-shadow .8s ease;
      animation: cardIn .8s ease both;
    }
    @media (min-width: 480px) { .card { border-radius: 28px; padding: 50px 44px 44px; } }
    @keyframes cardIn { from { opacity: 0; transform: translateY(24px); } to { opacity: 1; transform: translateY(0); } }

    #app.morning .card {
      background: rgba(255,255,255,.55);
      backdrop-filter: blur(20px);
      border: 1px solid rgba(255,255,255,.7);
      box-shadow: 0 20px 60px rgba(196,64,90,.12);
    }
    #app.night .card {
      background: rgba(255,255,255,.06);
      backdrop-filter: blur(20px);
      border: 1px solid rgba(255,255,255,.12);
      box-shadow: 0 20px 60px rgba(0,0,0,.4);
    }

    .card-icon {
      font-size: 36px; margin-bottom: 14px; display: block;
      animation: iconPulse 3s ease-in-out infinite;
    }
    @media (min-width: 480px) { .card-icon { font-size: 40px; } }
    @keyframes iconPulse { 0%,100% { transform: scale(1); } 50% { transform: scale(1.08); } }

    .greeting-small {
      font-family: 'Cormorant Garamond', serif;
      font-size: 13px; letter-spacing: 3px; text-transform: uppercase;
      margin-bottom: 8px;
    }
    #app.morning .greeting-small { color: #b06070; }
    #app.night   .greeting-small { color: rgba(200,160,255,.7); }

    .greeting-main {
      font-family: 'Cormorant Garamond', serif;
      font-size: 40px; font-weight: 300; line-height: 1.05;
      margin-bottom: 16px; transition: opacity .4s;
    }
    @media (min-width: 380px) { .greeting-main { font-size: 46px; } }
    @media (min-width: 480px) { .greeting-main { font-size: 52px; } }
    #app.morning .greeting-main { color: #6a1a2e; }
    #app.night   .greeting-main { color: #e8d8ff; }

    .divider { width: 60px; height: 1px; margin: 0 auto 20px; }
    #app.morning .divider { background: linear-gradient(90deg, transparent, #c4405a, transparent); }
    #app.night   .divider { background: linear-gradient(90deg, transparent, rgba(160,120,255,.6), transparent); }

    .greeting-sub {
      font-family: 'Cormorant Garamond', serif;
      font-size: 16px; font-style: italic; line-height: 1.6;
      margin-bottom: 20px; transition: opacity .4s;
    }
    @media (min-width: 480px) { .greeting-sub { font-size: 18px; } }
    #app.morning .greeting-sub { color: #9a5060; }
    #app.night   .greeting-sub { color: rgba(200,170,255,.75); }

    .poem {
      font-size: 14px; line-height: 1.9; letter-spacing: .3px;
      transition: opacity .4s;
    }
    #app.morning .poem { color: #7a5060; }
    #app.night   .poem { color: rgba(200,180,240,.65); }

    /* ── Send button ── */
    .send-btn {
      margin-top: 24px; padding: 13px 36px; border-radius: 50px;
      border: none; cursor: pointer;
      font-family: 'Nunito', sans-serif; font-size: 14px; font-weight: 400;
      letter-spacing: 1px; transition: all .3s ease; color: white;
      -webkit-tap-highlight-color: transparent;
      touch-action: manipulation;
    }
    @media (min-width: 480px) { .send-btn { padding: 13px 40px; } }
    #app.morning .send-btn { background: linear-gradient(135deg,#c4405a,#e86c8a); box-shadow: 0 6px 20px rgba(196,64,90,.35); }
    #app.night   .send-btn { background: linear-gradient(135deg,#5a2090,#8050d0); box-shadow: 0 6px 20px rgba(80,30,150,.5); }
    .send-btn:hover  { transform: translateY(-2px); }
    .send-btn:active { transform: scale(.97); }

    /* ── Notification toast ── */
    .notif {
      position: fixed; bottom: 24px; left: 50%;
      transform: translateX(-50%) translateY(100px);
      padding: 12px 24px; border-radius: 50px; font-size: 13px;
      color: white; transition: transform .4s ease;
      z-index: 999; white-space: nowrap; pointer-events: none;
      font-family: 'Nunito', sans-serif;
    }
    .notif.show       { transform: translateX(-50%) translateY(0); }
    .notif.m-notif    { background: linear-gradient(135deg,#c4405a,#e86c8a); }
    .notif.n-notif    { background: linear-gradient(135deg,#5a2090,#8050d0); }
  </style>
</head>
<body>

<div id="app" class="morning">
  <div class="stars" id="stars"></div>

  <div class="celestial">
    <div class="sun-wrap"><div class="sun-body"></div></div>
    <div class="moon-wrap"><div class="moon-body"></div></div>
  </div>

  <div class="content">

    <div class="toggle-wrap" role="group" aria-label="Selecionar período">
      <button class="toggle-btn active" id="btn-morning" onclick="setMode('morning')">☀️ Bom dia</button>
      <button class="toggle-btn"        id="btn-night"   onclick="setMode('night')">🌙 Boa noite</button>
    </div>

    <div class="lang-section">
      <span class="lang-label">Idioma</span>
      <div class="lang-grid" id="lang-grid"></div>
    </div>

    <div class="card" id="main-card">
      <span class="card-icon" id="card-icon">🌹</span>
      <div class="greeting-small" id="greeting-small">uma mensagem de</div>
      <div class="greeting-main"  id="greeting-main">Bom Dia</div>
      <div class="divider"></div>
      <div class="greeting-sub"   id="greeting-sub">Que o amanhecer ilumine cada detalhe do seu sorriso...</div>
      <div class="poem"           id="poem">Acordei pensando em você,<br>no jeito gentil com que o dia começa<br>quando sei que você existe nele.</div>
      <button class="send-btn" id="send-btn" onclick="copyGreeting()">✉️ &nbsp;Copiar mensagem</button>
    </div>

  </div>
</div>

<div class="notif" id="notif"></div>

<script>
const langs = [
  { code:'pt', name:'Português 🇧🇷' },
  { code:'en', name:'English 🇬🇧' },
  { code:'es', name:'Español 🇪🇸' },
  { code:'fr', name:'Français 🇫🇷' },
  { code:'it', name:'Italiano 🇮🇹' },
  { code:'de', name:'Deutsch 🇩🇪' },
  { code:'ja', name:'日本語 🇯🇵' },
  { code:'ar', name:'العربية 🇸🇦' },
  { code:'ru', name:'Русский 🇷🇺' },
  { code:'zh', name:'中文 🇨🇳' },
  { code:'ko', name:'한국어 🇰🇷' },
  { code:'hi', name:'हिन्दी 🇮🇳' },
];

const data = {
  pt: {
    morning:{ main:'Bom Dia',      small:'uma mensagem de',  icon:'🌹', sub:'Que o amanhecer ilumine cada detalhe do seu sorriso...', poem:'Acordei pensando em você,\nno jeito gentil com que o dia começa\nquando sei que você existe nele.' },
    night:  { main:'Boa Noite',    small:'um sussurro de',   icon:'🌙', sub:'Que as estrelas guardem seus sonhos mais lindos...', poem:'Quando a noite cobre o mundo,\nmeus pensamentos te encontram\ne ficam por perto até o amanhecer.' }
  },
  en: {
    morning:{ main:'Good Morning', small:'a message of',     icon:'🌸', sub:'May the sunrise paint your day in golden light...', poem:"I woke up thinking of you,\nin the quiet way a morning begins\nwhen you're in the world." },
    night:  { main:'Good Night',   small:'a whisper of',     icon:'✨', sub:'May the stars keep watch over your sweetest dreams...', poem:"As night unfolds its velvet sky,\nmy thoughts drift gently to you—\nstay close until the morning." }
  },
  es: {
    morning:{ main:'Buenos Días',  small:'un mensaje de',    icon:'🌺', sub:'Que el alba dibuje tu sonrisa más bella...', poem:'Desperté pensando en ti,\nen la manera suave en que comienza el día\ncuando tú existes en él.' },
    night:  { main:'Buenas Noches',small:'un susurro de',    icon:'🌟', sub:'Que las estrellas cuiden tus sueños más dulces...', poem:'Cuando la noche cubre el mundo,\nmis pensamientos te encuentran\ny se quedan cerca hasta el amanecer.' }
  },
  fr: {
    morning:{ main:'Bonjour',      small:'un message de',    icon:'🌷', sub:"Que l'aurore illumine chaque détail de ton sourire...", poem:'Je me suis réveillé en pensant à toi,\ndans la façon douce dont la journée commence\nlorsque tu existes en elle.' },
    night:  { main:'Bonne Nuit',   small:'un murmure de',    icon:'🌙', sub:'Que les étoiles gardent tes rêves les plus tendres...', poem:"Quand la nuit recouvre le monde,\nmes pensées te retrouvent\net restent près de toi jusqu'à l'aube." }
  },
  it: {
    morning:{ main:'Buongiorno',   small:'un messaggio di',  icon:'🌹', sub:"Che l'alba illumini ogni dettaglio del tuo sorriso...", poem:"Mi sono svegliato pensando a te,\nnel modo gentile in cui comincia il giorno\nquando so che tu esisti in esso." },
    night:  { main:'Buona Notte',  small:'un sussurro di',   icon:'⭐', sub:"Che le stelle custodiscano i tuoi sogni più dolci...", poem:"Quando la notte copre il mondo,\ni miei pensieri ti trovano\ne restano vicini fino all'alba." }
  },
  de: {
    morning:{ main:'Guten Morgen', small:'eine Botschaft von',icon:'🌼', sub:'Möge der Morgen dein Lächeln in goldenes Licht tauchen...', poem:'Ich bin mit Gedanken an dich aufgewacht,\nauf die sanfte Art, wie ein Morgen beginnt,\nwenn du darin existierst.' },
    night:  { main:'Gute Nacht',   small:'ein Flüstern von', icon:'🌠', sub:'Mögen die Sterne deine süßesten Träume bewachen...', poem:'Wenn die Nacht die Welt bedeckt,\nfinden meine Gedanken dich\nund bleiben bis zum Morgengrauen nah bei dir.' }
  },
  ja: {
    morning:{ main:'おはようございます', small:'愛の言葉', icon:'🌸', sub:'朝の光があなたの笑顔を照らしますように...', poem:'目を覚ますとあなたのことを考えていた、\nあなたがこの世界にいるとき\n朝がそっと始まる、その優しさの中で。' },
    night:  { main:'おやすみなさい',    small:'ひとこと',  icon:'🌙', sub:'星があなたの夢を守りますように...', poem:'夜が世界を覆う時、\n私の想いはあなたへ届く、\n夜明けまで、あなたのそばに。' }
  },
  ar: {
    morning:{ main:'صباح الخير', small:'رسالة من', icon:'🌺', sub:'...ليضيء الفجر كل تفصيل من ابتسامتك', poem:'استيقظت وأنا أفكر فيك،\nبالطريقة اللطيفة التي يبدأ بها الصباح\nحين تكون موجوداً في العالم.' },
    night:  { main:'تصبح على خير', small:'همسة',   icon:'✨', sub:'...لتحرس النجوم أحلامك الأجمل', poem:'حين يغطي الليل العالم،\nتجدك أفكاري\nوتبقى قريبة منك حتى الفجر.' }
  },
  ru: {
    morning:{ main:'Доброе утро',    small:'послание от', icon:'🌼', sub:'Пусть рассвет осветит каждую деталь твоей улыбки...', poem:'Я проснулся, думая о тебе,\nв тихой нежности, с которой начинается утро,\nкогда ты есть в этом мире.' },
    night:  { main:'Спокойной ночи', small:'шёпот',      icon:'🌟', sub:'Пусть звёзды хранят твои самые сладкие сны...', poem:'Когда ночь накрывает мир,\nмои мысли находят тебя\nи остаются рядом до рассвета.' }
  },
  zh: {
    morning:{ main:'早上好', small:'一句心语', icon:'🌸', sub:'愿晨曦照亮你笑颜的每一个细节...', poem:'醒来，满脑子都是你，\n就像清晨轻柔的开始，\n因为你在这个世界上。' },
    night:  { main:'晚安',   small:'轻声',    icon:'🌙', sub:'愿星辰守护你最美好的梦境...', poem:'当夜色笼罩世界，\n我的思念找到了你，\n陪你直到黎明到来。' }
  },
  ko: {
    morning:{ main:'좋은 아침', small:'마음 담은', icon:'🌺', sub:'새벽빛이 당신의 미소 하나하나를 비추길...', poem:'눈을 뜨며 당신을 생각했어요,\n당신이 이 세상에 존재할 때\n아침이 조용히 시작되는 그 방식으로.' },
    night:  { main:'잘 자요',   small:'속삭임',   icon:'✨', sub:'별들이 당신의 가장 달콤한 꿈을 지켜주길...', poem:'밤이 세상을 감쌀 때,\n내 생각이 당신을 찾아가\n새벽까지 곁에 머물러요.' }
  },
  hi: {
    morning:{ main:'सुप्रभात',    small:'एक संदेश',      icon:'🌸', sub:'भोर की किरण तुम्हारी मुस्कान को रोशन करे...', poem:'मैं तुम्हारे बारे में सोचते हुए जागा,\nउस कोमल अंदाज़ में जैसे सुबह शुरू होती है\nजब तुम इस दुनिया में होते हो।' },
    night:  { main:'शुभ रात्रि', small:'एक फुसफुसाहट', icon:'🌙', sub:'सितारे तुम्हारे मीठे सपनों की रक्षा करें...', poem:'जब रात दुनिया को ढक लेती है,\nमेरे विचार तुम्हें ढूंढ लेते हैं\nऔर भोर तक तुम्हारे पास रहते हैं।' }
  }
};

let currentMode = 'morning';
let currentLang = 'pt';

/* ── Stars ── */
function buildStars() {
  const c = document.getElementById('stars');
  for (let i = 0; i < 60; i++) {
    const s = document.createElement('div');
    s.className = 'star';
    const sz = Math.random() * 2.5 + 0.5;
    s.style.cssText = `width:${sz}px;height:${sz}px;top:${Math.random()*90}%;left:${Math.random()*100}%;animation-delay:${(Math.random()*4).toFixed(1)}s;animation-duration:${(2+Math.random()*3).toFixed(1)}s`;
    c.appendChild(s);
  }
}

/* ── Petals (morning) ── */
function buildPetals() {
  for (let i = 0; i < 14; i++) {
    const p = document.createElement('div');
    p.className = 'petal';
    const sz = 8 + Math.random() * 10;
    const hue = 340 + Math.random() * 20;
    p.style.cssText = `width:${sz}px;height:${(sz*.7).toFixed(0)}px;left:${(Math.random()*100).toFixed(1)}%;top:${(-30+Math.random()*15).toFixed(0)}px;background:hsl(${hue},70%,75%);animation-delay:${(Math.random()*9).toFixed(1)}s;animation-duration:${(7+Math.random()*5).toFixed(1)}s`;
    document.getElementById('app').appendChild(p);
  }
}

/* ── Fireflies (night) ── */
function buildFireflies() {
  for (let i = 0; i < 10; i++) {
    const f = document.createElement('div');
    f.className = 'firefly';
    const fx = ((Math.random()-.5)*130).toFixed(0);
    const fy = ((Math.random()-.5)*130).toFixed(0);
    f.style.cssText = `left:${(10+Math.random()*80).toFixed(1)}%;top:${(20+Math.random()*60).toFixed(1)}%;--fx:${fx}px;--fy:${fy}px;animation-delay:${(Math.random()*7).toFixed(1)}s;animation-duration:${(5+Math.random()*4).toFixed(1)}s`;
    document.getElementById('app').appendChild(f);
  }
}

/* ── Language chips ── */
function buildLangGrid() {
  const g = document.getElementById('lang-grid');
  langs.forEach(l => {
    const btn = document.createElement('button');
    btn.className = 'lang-chip' + (l.code === currentLang ? ' active' : '');
    btn.textContent = l.name;
    btn.dataset.code = l.code;
    btn.onclick = () => setLang(l.code);
    g.appendChild(btn);
  });
}

function setMode(mode) {
  currentMode = mode;
  document.getElementById('app').className = mode;
  document.getElementById('btn-morning').className = 'toggle-btn' + (mode === 'morning' ? ' active' : '');
  document.getElementById('btn-night').className   = 'toggle-btn' + (mode === 'night'   ? ' active' : '');
  updateCard();
}

function setLang(lang) {
  currentLang = lang;
  document.querySelectorAll('.lang-chip').forEach(b => {
    b.className = 'lang-chip' + (b.dataset.code === lang ? ' active' : '');
  });
  updateCard();
}

function updateCard() {
  const d = data[currentLang][currentMode];
  fadeUpdate('greeting-main',  d.main);
  fadeUpdate('greeting-sub',   d.sub);
  fadeUpdate('poem',           d.poem.replace(/\n/g, '<br>'));
  fadeUpdate('greeting-small', d.small);
  document.getElementById('card-icon').textContent = d.icon;
}

function fadeUpdate(id, html) {
  const el = document.getElementById(id);
  if (!el) return;
  el.style.transition = 'opacity .35s';
  el.style.opacity = '0';
  setTimeout(() => { el.innerHTML = html; el.style.opacity = '1'; }, 300);
}

function copyGreeting() {
  const d = data[currentLang][currentMode];
  const text = `${d.main}\n\n${d.sub}\n\n${d.poem}`;
  navigator.clipboard.writeText(text)
    .then(() => showNotif('✓ Copiado com amor para a área de transferência'))
    .catch(() => showNotif('💌 Mensagem pronta para compartilhar!'));
}

function showNotif(msg) {
  const n = document.getElementById('notif');
  n.textContent = msg;
  n.className = 'notif show ' + (currentMode === 'morning' ? 'm-notif' : 'n-notif');
  setTimeout(() => { n.className = 'notif'; }, 2800);
}

/* ── Init ── */
buildStars();
buildPetals();
buildFireflies();
buildLangGrid();
</script>
</body>
</html>
